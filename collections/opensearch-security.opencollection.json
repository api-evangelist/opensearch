            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://{cluster-host}:9200/_plugins/_security/api/account",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Change current user password"
        }
      ]
    },
